	<classpathentry combineaccessrules="false" kind="src" path="/CoreOtherEntity"/>
	<classpathentry combineaccessrules="false" kind="src" path="/CoreResource"/>
	<classpathentry combineaccessrules="false" kind="src" path="/CoreInfrastructure"/>
	<classpathentry combineaccessrules="false" kind="src" path="/Common"/>
	<classpathentry combineaccessrules="false" kind="src" path="/CoreCommon"/>
	<classpathentry combineaccessrules="false" kind="src" path="/CoreData"/>
	<classpathentry kind="output" path="bin"/>
</classpath>
